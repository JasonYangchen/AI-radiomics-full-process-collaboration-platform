# Application
APP_NAME=RadiomicsHub
APP_VERSION=1.0.0
DEBUG=true

# Security
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/radiomics

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / S3 Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=radiomics
MINIO_SECURE=false

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost"]

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# File Upload
MAX_UPLOAD_SIZE=524288000
ALLOWED_EXTENSIONS=.dcm,.nrrd,.nii,.nii.gz

# Radiomics Configuration (JSON)
RADIOMICS_CONFIG={"binWidth":25,"interpolator":"sitkBSpline","enableCExtensions":true}